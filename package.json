{
  "name": "opencart",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {

    "pretest": "echo Running tests on $ENV environment",

    "test:master":     "npx playwright test --grep @master",
    "test:sanity":     "npx playwright test --grep @sanity",
    "test:smoke":      "npx playwright test --grep @smoke",
    "test:regression": "npx playwright test --grep @regression",

    "test:master:headed":     "npx playwright test --grep @master --headed",
    "test:sanity:headed":     "npx playwright test --grep @sanity --headed",
    "test:smoke:headed":      "npx playwright test --grep @smoke --headed",
    "test:regression:headed": "npx playwright test --grep @regression --headed",

    "test:master:debug":     "npx playwright test --grep @master --debug",
    "test:sanity:debug":     "npx playwright test --grep @sanity --debug",
    "test:smoke:debug":      "npx playwright test --grep @smoke --debug",
    "test:regression:debug": "npx playwright test --grep @regression --debug",

    "test:master:failed":     "npx playwright test --grep @master --last-failed",
    "test:sanity:failed":     "npx playwright test --grep @sanity --last-failed",
    "test:smoke:failed":      "npx playwright test --grep @smoke --last-failed",
    "test:regression:failed": "npx playwright test --grep @regression --last-failed",

    "test:qa:master":          "cross-env ENV=qa npx playwright test --grep @master",
    "test:qa:sanity":          "cross-env ENV=qa npx playwright test --grep @sanity",
    "test:qa:smoke":           "cross-env ENV=qa npx playwright test --grep @smoke",
    "test:qa:regression":      "cross-env ENV=qa npx playwright test --grep @regression",

    "test:uat:master":         "cross-env ENV=uat npx playwright test --grep @master",
    "test:uat:sanity":         "cross-env ENV=uat npx playwright test --grep @sanity",
    "test:uat:smoke":          "cross-env ENV=uat npx playwright test --grep @smoke",
    "test:uat:regression":     "cross-env ENV=uat npx playwright test --grep @regression",

    "test:prod:master":        "cross-env ENV=prod npx playwright test --grep @master",
    "test:prod:sanity":        "cross-env ENV=prod npx playwright test --grep @sanity",
    "test:prod:smoke":         "cross-env ENV=prod npx playwright test --grep @smoke",
    "test:prod:regression":    "cross-env ENV=prod npx playwright test --grep @regression"


  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "allure-playwright": "^3.6.0"
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "xlsx": "^0.18.5"
  }
}
